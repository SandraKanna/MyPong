# Copy this file to .env and fill in the values before running "make up".
# .env is gitignored — never commit real secrets.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=mypong
POSTGRES_USER=mypong_user
POSTGRES_PASSWORD=change_me

# Must match POSTGRES_USER / POSTGRES_PASSWORD above — same credential,
# written twice for two different consumers (Docker Compose env vars vs. pg URL).
DATABASE_URL=postgresql://mypong_user:change_me@postgres:5432/mypong

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Service-to-service ────────────────────────────────────────────────────────
# Pre-shared key identifying game-service (and future WS satellite services) as
# trusted backend processes to gateway-ws. NOT a user JWT — a different auth layer.
# Minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INTERNAL_SERVICE_SECRET=
