# WebSocket gateway. Authenticates browser clients via JWT and routes messages
# to backend services (game-service, matchmaking-service, etc.) once those exist.
# No database connection — stateless except for open socket handles.

PORT=4500

# Must match the JWT_SECRET used by auth-service to sign access tokens.
# Minimum 32 characters. Copy from the root .env.
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
