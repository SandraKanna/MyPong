PORT=4001
# Must point to the standalone Postgres container below, NOT the
# Compose one (postgres:5432) — that hostname only resolves inside
# the Docker network. See README "Local (native)" for the docker run
# command this connects to.
DATABASE_URL=postgresql://mypong_user:dev_password@localhost:5433/mypong
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
