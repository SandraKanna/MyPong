# WebSocket URL of gateway-ws (internal Docker network address in production)
GATEWAY_WS_URL=ws://gateway-ws:4500

# Pre-shared secret for authenticating internal service connections to gateway-ws.
# Must be identical across all internal services and the gateway.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET=changeme_min_32_chars_xxxxxxxxxxxxxxxx
