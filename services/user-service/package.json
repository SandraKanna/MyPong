{
  "name": "@mypong/user-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "eslint src tests",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate:up": "node-pg-migrate up --migrations-table pgmigrations_user",
    "migrate:down": "node-pg-migrate down --migrations-table pgmigrations_user",
    "migrate:create": "node-pg-migrate create --migrations-table pgmigrations_user",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "fastify": "^5.8.5",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "sharp": "^0.35.2",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.14",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
