PORT=4002
# Same Postgres instance as auth-service. In native dev, point to the
# standalone container (localhost:5433), not the Compose one (postgres:5432).
# The pgmigrations table is shared — node-pg-migrate tracks migrations per
# service by the migration filenames, not by table name.
DATABASE_URL=postgresql://mypong_user:dev_password@localhost:5433/mypong
