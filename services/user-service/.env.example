PORT=4002
# Same Postgres instance as auth-service. In native dev, point to the
# standalone container (localhost:5433), not the Compose one (postgres:5432).
# Each service uses its own migrations tracking table (--migrations-table flag
# in npm scripts) to avoid checkOrder conflicts on the shared Postgres instance.
DATABASE_URL=postgresql://mypong_user:dev_password@localhost:5433/mypong
# Directory where avatar files are stored. In Docker this is the avatars_data
# volume mount (/var/www/avatars). In native dev, create the directory manually:
#   mkdir -p ./avatars-dev
# The path must exist before the service starts — the service does not create it.
AVATARS_DIR=./avatars-dev
