# 4000 is the official port. On macOS, the Nx daemon (nxd) often
# squats on 4000 — if `npm run dev` fails with EADDRINUSE, use 4010
# instead (and pass it to smoke-test.sh as an argument).
PORT=4000
# Must be IDENTICAL to JWT_SECRET in auth-service/.env — gateway-api
# verifies signatures that auth-service produces.
JWT_SECRET=
# NEVER add JWT_REFRESH_SECRET here — exclusive to auth-service.
AUTH_SERVICE_URL=http://localhost:4001

# Required for gateway-api to boot (Zod validates all upstream URLs at
# startup) — but /api/users/* is NOT reachable in native mode: user-service
# has no host port mapping and no native flow of its own. This value only
# lets the process start so /api/auth/* stays testable natively; requests
# to /api/users/* will fail with a connection error, and that's expected.
USER_SERVICE_URL=http://localhost:4002