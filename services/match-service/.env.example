# match-service: owns match lifecycle (pairing, result persistence).
# WS client only — connects outward to gateway-ws, never exposes a WS port.
# PostgreSQL connection string. For native dev, point to your local instance
# (port 5433 if Postgres 16 is already running on the default 5432).
DATABASE_URL=postgresql://mypong_user:dev_password@localhost:5433/mypong

# URL of the gateway-ws WebSocket hub. Inside Docker this resolves to the
# internal container name. For native dev, point to wherever gateway-ws is running.
GATEWAY_WS_URL=ws://localhost:4500

# Pre-shared key for service-to-service authentication with gateway-ws.
# Must match INTERNAL_SERVICE_SECRET in gateway-ws. Minimum 32 characters.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INTERNAL_SERVICE_SECRET=
