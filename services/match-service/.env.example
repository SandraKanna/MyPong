# match-service: owns match lifecycle and persists match history.
# WS client only — connects outward to gateway-ws, never exposes a WS port.
# The HTTP server on PORT is solely for Docker healthchecks.

PORT=4502

# Postgres connection string. Use localhost:5433 for native dev (avoids port
# clash with a local Postgres install on 5432). Use the hostname "postgres"
# inside Docker Compose — docker-compose.yml sets DATABASE_URL from the root .env.
DATABASE_URL=postgresql://mypong_user:change_me@localhost:5433/mypong

# Pre-shared key for service-to-service authentication with gateway-ws.
# This is NOT a user JWT — it identifies this process as a trusted backend
# service rather than a browser client. Must match the INTERNAL_SERVICE_SECRET
# configured in gateway-ws when service-to-service auth is implemented.
# Minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
INTERNAL_SERVICE_SECRET=
